# FairShare API server (never expose these in the browser)
PORT=3840

# Owner-only dashboard (/fs-owner-console.html + GET /api/owner/dashboard)
# Generate: openssl rand -hex 32
ADMIN_PANEL_SECRET=

# Supabase service role — required for accurate user / signup counts (Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — AI writing assistant
ANTHROPIC_API_KEY=

# Copyleaks — https://docs.copyleaks.com/ (login → submit scan → results)
COPYLEAKS_EMAIL=
COPYLEAKS_API_KEY=

# PlagiarismSearch — https://plagiarismsearch.com/account/api (alternative to Copyleaks)
PLAGIARISMSEARCH_API_KEY=

# Daily.co — https://dashboard.daily.co/developers
DAILY_API_KEY=

# Stripe — institutional per-seat billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring price ID from Stripe Dashboard (per-seat unit)
STRIPE_PRICE_PER_SEAT=

# Public URL of this app (for Stripe redirects), e.g. http://localhost:3840
PUBLIC_APP_URL=http://localhost:3840
